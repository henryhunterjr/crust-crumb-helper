{
  "manifest_version": 3,
  "name": "Krusty Skool Helper",
  "version": "1.0.0",
  "description": "Paste & send DMs and welcome posts on Skool with one click. Companion to the Crust & Crumb Helper.",
  "permissions": ["clipboardRead", "activeTab", "storage"],
  "host_permissions": ["https://www.skool.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.skool.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Krusty Skool Helper",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": { "48": "icon.png", "128": "icon.png" }
}