# Crust & Crumb roster agent — copy to .env and fill in. Never commit .env.

# Your INGEST_API_KEY for the Helper backend (same key ingest-brief uses).
INGEST_API_KEY=

# Where the agent posts the roster. Default points at the live Helper backend.
INGEST_ROSTER_URL=https://anponqqhjugwflakydsf.supabase.co/functions/v1/ingest-roster

# The Skool members directory page.
SKOOL_MEMBERS_URL=https://www.skool.com/crust-crumb-academy-7621/-/members

# Which community this roster read belongs to. Inferred from SKOOL_MEMBERS_URL
# when omitted (e.g. "crust-crumb-academy" or "from-oven-to-market"). Set
# explicitly if you point at a URL that doesn't include the slug directly.
COMMUNITY_SLUG=crust-crumb-academy

# Chrome remote-debugging endpoint for the dedicated automation profile
# (roster-agent-profile, signed in to Skool once). run-roster.ps1 launches it.
CHROME_CDP_URL=http://localhost:9223

# Pacing — behave like a person, not a scraper.
ROSTER_MIN_DELAY_MS=1200
ROSTER_MAX_DELAY_MS=2800
ROSTER_MAX_PAGES=80

# A full read covers the whole roster, so members no longer present get
# flagged "missing_from_roster". Set to false for a partial/spot read.
ROSTER_FULL=true
